# =============================================================================
#  RAG Constructor — пример файла окружения
#  Скопируйте этот файл в .env и заполните своими значениями:
#      cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# Можно задать либо DATABASE_URL целиком, либо отдельные POSTGRES_* параметры.
# Если DATABASE_URL задан, он имеет приоритет.
# -----------------------------------------------------------------------------

# Отдельные параметры (рекомендуется для локальной разработки)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_constructor

# Или полный URL (например для облачных баз / Heroku / Railway)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# Qdrant (векторная БД)
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key   # нужен только для Qdrant Cloud

# -----------------------------------------------------------------------------
# Redis / Celery (очередь задач)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# OpenAI / LLM
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.vsegpt.ru/v1   # для прокси-провайдера

# -----------------------------------------------------------------------------
# Файловое хранилище (куда сохранять загружаемые файлы)
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
